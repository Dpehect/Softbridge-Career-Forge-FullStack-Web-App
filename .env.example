# ── Site (Vercel Production) ───────────────────────────────────────────────
# After first deploy: set to your production URL (https://…)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ── Ollama ─────────────────────────────────────────────────────────────────
# LOCAL DEV only — leave EMPTY on Vercel (localhost is unreachable from serverless).
# If empty / production: site works; AI pill shows "Local AI unavailable".
# Optional remote: https://your-ollama-tunnel.example.com
# OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3
