# ── Site (Vercel Production) ───────────────────────────────────────────────
# Project Settings → Domains altındaki URL (https:// ile)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ── Ollama (opsiyonel — Vercel sunucusundan localhost’a erişilemez) ─────────
# Yerel geliştirme: http://localhost:11434
# Production: public HTTPS endpoint (ngrok / cloud Ollama) veya boş bırakın
# Boş bırakılırsa AI status “çevrimdışı” görünür; tarayıcı içi analiz çalışmaya devam eder.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── OpenAI (opsiyonel — gelecekte sunucu tarafı için) ───────────────────────
# OPENAI_API_KEY=
